# GRIP Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://grip:grip_dev@localhost:5432/grip

# Demo mode: true = use seed data only, no external API calls
DEMO_MODE=true

# ENTSO-E Transparency Platform (register at https://transparency.entsoe.eu/)
ENTSOE_API_KEY=your_key_here

# Google BigQuery for GDELT (optional; falls back to DOC API)
GDELT_PROJECT_ID=your_project_id

# Copernicus Climate Data Store (register at https://cds.climate.copernicus.eu/)
COPERNICUS_API_KEY=your_key_here

# CORS (for frontend development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
